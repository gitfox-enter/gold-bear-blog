---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import config from '@/site-config'

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)

const imagePath = config.logo.src
const images = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/*.{jpeg,jpg,png,gif,avif,webp,svg}'
)
if (!images[imagePath])
  throw new Error(
    `"${imagePath}" does not exist in glob: "src/assets/*.{jpeg,jpg,png,gif,avif,webp}"`
  )
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB9'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <Image
        src={images[imagePath]()}
        alt={config.logo.alt || 'Profile'}
        class='h-28 w-auto rounded-full border p-1'
        loading='eager'
        fetchpriority='high'
      />

      <div class='flex flex-col items-center gap-y-4'>
        <h1 class='text-3xl font-medium'>{config.author}</h1>
        <div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
          <Label title='亳州'>
            <Icon name='location' class='size-5' slot='icon' />
          </Label>
          <Label
            title='GitHub'
            as='a'
            href='https://github.com/gitfox-enter'
            target='_blank'
          >
            <Icon name='github' class='size-5' slot='icon' />
          </Label>
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='关于我'>
        <p class='text-muted-foreground'>
          亳州学院酒店管理专业在读，正在探索 AI 编程。喜欢用脚本解决实际生活中的问题 —— 从校园网自动登录到羊毛线报监控，
          能用代码自动化的事情绝不手动重复。WorkBuddy 重度用户。
        </p>
      </Section>

      {
        allPostsByDate.length > 0 && (
          <Section title='文章'>
            <ul class='flex flex-col gap-y-1.5 sm:gap-y-2'>
              {allPostsByDate.map((p) => (
                <li class='flex flex-col gap-x-2 sm:flex-row'>
                  <PostPreview post={p} />
                </li>
              ))}
            </ul>
            <Button title='更多文章' class='w-fit self-end' href='/gold-bear-blog/blog' variant='ahead' />
          </Section>
        )
      }

      <Section title='教育'>
        <Card
          heading='亳州学院'
          subheading='酒店管理 · 本科'
          date='2025 - 2027'
        >
          <div class='flex items-start gap-x-4 mb-3'>
            <img src='/gold-bear-blog/bzuu-logo.png' alt='亳州学院' class='h-14 w-auto max-w-[150px] rounded-lg object-contain' loading='lazy' />
            <div>
              <a href='https://www.bzuu.edu.cn' target='_blank' class='text-sm text-primary hover:underline'>www.bzuu.edu.cn ↗</a>
              <ul class='ms-4 mt-2 list-disc text-muted-foreground'>
                <li>主修课程：酒店管理概论、旅游学概论、服务运营管理</li>
                <li>课外自学：AI 编程、自动化脚本、Linux</li>
              </ul>
            </div>
          </div>
        </Card>
      </Section>

      <Section title='小成果'>
        <Card
          as='a'
          heading='亳州学院校园网自动登录'
          subheading='脚本猫发布，简化校园网认证流程'
          date='2026'
          href='https://scriptcat.org/zh-CN/script-show-page/5981'
        />
        <Card
          as='a'
          heading='个人博客'
          subheading='基于 Astro + astro-theme-pure 搭建'
          date='2026'
          href='https://gitfox-enter.github.io/gold-bear-blog/'
        />
        <Card
          heading='青龙面板自动签到'
          subheading='多平台自动签到脚本管理'
          date='2026'
        />
      </Section>

      <Section title='网站服务'>
        <Card
          as='a'
          heading='站点更新监控'
          subheading='自动化多站点巡检面板：健康趋势 / 关键词排行 / 最新内容流'
          date='2026'
          href='https://gitfox-enter.github.io/site-update-monitor/'
        />
        <Card
          heading='羊毛线报监控'
          subheading='实时监控多个羊毛线报站点，自动推送最新优惠信息'
          date='2026'
        >
          <p class='text-sm text-muted-foreground'>
            基于 Playwright + 自定义解析器，覆盖 24 个站点，自动抓取并过滤优惠线报。
          </p>
        </Card>
      </Section>

      <Section title='技能'>
        <div class='flex flex-col gap-y-4'>
          <!-- 已掌握 -->
          <div>
            <h4 class='mb-2 text-sm font-medium'>已掌握</h4>
            <div class='flex flex-wrap gap-2'>
              {['Node.js', 'Python', 'Astro', '自动化脚本', '爬虫开发', 'Electron', 'WorkBuddy', '海阔视界'].map(skill => (
                <span class='rounded-full border border-primary/30 bg-primary/5 px-3 py-1 text-sm text-foreground'>{skill}</span>
              ))}
            </div>
          </div>
          <!-- 在学中 -->
          <div>
            <h4 class='mb-2 text-sm font-medium'>在学中</h4>
            <div class='flex flex-wrap gap-2'>
              {['AI 编程', 'Docker', 'Linux'].map(skill => (
                <span class='rounded-full border border-dashed px-3 py-1 text-sm text-muted-foreground'>{skill}</span>
              ))}
            </div>
          </div>
          <!-- 证书 -->
          <div>
            <h4 class='mb-2 text-sm font-medium'>证书/资质</h4>
            <div class='flex flex-wrap gap-2'>
              {['C2 驾驶证', '普通话二级乙等'].map(skill => (
                <span class='rounded-full border border-muted px-3 py-1 text-sm text-muted-foreground/70'>{skill}</span>
              ))}
            </div>
          </div>
        </div>
      </Section>
    </div>
    <Quote class='mt-12' />
  </main>
</PageLayout>
