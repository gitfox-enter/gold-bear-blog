---
import PageLayout from '@/layouts/CommonPage.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import wechat from '@/assets/images/wechat-tip.jpg'
---

<PageLayout title='赞助' view>
  <p>如果我的内容对你有所帮助，欢迎请我喝杯咖啡 ☕。</p>
  <p>你的支持是我持续输出的动力！</p>
  
  <p>国内方式：微信赞赏</p>
  <Sponsorship
    methods={[
      { name: '微信赞赏', icon: 'wechat-pay', image: wechat }
    ]}
  />
</PageLayout>
